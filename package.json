{
  "name": "ed-jump-counter",
  "version": "0.1.0",
  "description": "Elite Dangerous jump counter for second screen",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "electron:dev": "electron .",
    "package": "electron-builder",
    "start": "npm run build && electron ."
  },
  "keywords": [
    "elite-dangerous",
    "jump-counter",
    "desktop",
    "electron"
  ],
  "author": "sam-cogan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sam-cogan/ed-jump-counter.git"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.ed.jumpcounter",
    "productName": "ED Jump Counter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
